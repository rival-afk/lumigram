<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">
    <aapt:attr name="android:drawable">
        <vector
            android:name="root"
            android:width="320dp"
            android:height="320dp"
            android:viewportWidth="320"
            android:viewportHeight="320">
            <group
                android:name="scaleme"
                android:pivotX="160"
                android:pivotY="160"
                android:scaleX="0.01"
                android:scaleY="0.01">
                <path
                    android:name="circle_bg"
                    android:fillColor="@color/ic_launcher_background"
                    android:pathData="M 160 160 m -140 0 a 140 140 0 1 0 280 0 a 140 140 0 1 0 -280 0 Z" />
                <path
                    android:name="lumigram_l"
                    android:fillColor="#FFFFFF"
                    android:pathData="M 130 100 L 130 200 C 130 210 138 218 148 218 L 180 218 L 180 200 L 148 200 L 148 100 Z
                                 M 130 100 L 200 100 L 200 118 L 148 118 L 148 140 L 195 140 L 195 158 L 148 158 L 148 180 L 200 180 L 200 198 L 130 198 Z" />
            </group>
        </vector>
    </aapt:attr>
    <target android:name="scaleme">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="scaleX"
                    android:duration="600"
                    android:valueFrom="0.01"
                    android:valueTo="1"
                    android:valueType="floatType"
                    android:interpolator="@android:interpolator/fast_out_extra_slow_in" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:duration="600"
                    android:valueFrom="0.01"
                    android:valueTo="1"
                    android:valueType="floatType"
                    android:interpolator="@android:interpolator/fast_out_extra_slow_in" />
            </set>
        </aapt:attr>
    </target>
</animated-vector>

<animated-vector xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt">
    <aapt:attr name="android:drawable">
        <vector
            android:name="splash"
            android:width="320dp"
            android:height="320dp"
            android:viewportWidth="320"
            android:viewportHeight="320">
            <group
                android:name="scaleme"
                android:pivotX="160"
                android:pivotY="160"
                android:scaleX="1"
                android:scaleY="1">
                <group android:name="bg">
                    <path
                        android:name="circle"
                        android:pathData="M 160 110 C 146.744 110 134.018 115.271 124.645 124.645 C 115.271 134.018 110 146.744 110 160 C 110 173.256 115.271 185.982 124.645 195.355 C 134.018 204.729 146.744 210 160 210 C 173.256 210 185.982 204.729 195.355 195.355 C 204.729 185.982 210 173.256 210 160 C 210 146.744 204.729 134.018 195.355 124.645 C 185.982 115.271 173.256 110 160 110 Z"
                        android:fillColor="@color/ic_launcher_background"
                        android:fillAlpha="0"
                        android:strokeWidth="1" />
                </group>
                <group
                    android:name="fg"
                    android:pivotX="160"
                    android:pivotY="160"
                    android:scaleX="0.5"
                    android:scaleY="0.5">
                    <clip-path
                        android:name="mask"
                        android:pathData="M 160 60 C 133.489 60 108.036 70.543 89.289 89.289 C 70.543 108.036 60 133.489 60 160 C 60 186.511 70.543 211.964 89.289 230.711 C 108.036 249.457 133.489 260 160 260 C 186.511 260 211.964 249.457 230.711 230.711 C 249.457 211.964 260 186.511 260 160 C 260 133.489 249.457 108.036 230.711 89.289 C 211.964 70.543 186.511 60 160 60 Z" />
                    <group
                        android:name="logo_group"
                        android:pivotX="160"
                        android:pivotY="160"
                        android:scaleX="0.5"
                        android:scaleY="0.5">
                        <path
                            android:name="logo_ring"
                            android:pathData="M 160 80 C 115.817 80 80 115.817 80 160 C 80 204.183 115.817 240 160 240 C 204.183 240 240 204.183 240 160 C 240 115.817 204.183 80 160 80 Z M 160 100 C 126.863 100 100 126.863 100 160 C 100 193.137 126.863 220 160 220 C 193.137 220 220 193.137 220 160 C 220 126.863 193.137 100 160 100 Z"
                            android:fillColor="#FFFFFF"
                            android:fillAlpha="0"
                            android:strokeWidth="1" />
                        <path
                            android:name="logo_dot"
                            android:pathData="M 160 150 C 154.477 150 150 154.477 150 160 C 150 165.523 154.477 170 160 170 C 165.523 170 170 165.523 170 160 C 170 154.477 165.523 150 160 150 Z"
                            android:fillColor="#FFFFFF"
                            android:fillAlpha="0"
                            android:strokeWidth="1" />
                    </group>
                </group>
            </group>
        </vector>
    </aapt:attr>
    <target android:name="circle">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="pathData"
                    android:startOffset="200"
                    android:duration="600"
                    android:valueFrom="M 160 110 C 146.744 110 134.018 115.271 124.645 124.645 C 115.271 134.018 110 146.744 110 160 C 110 173.256 115.271 185.982 124.645 195.355 C 134.018 204.729 146.744 210 160 210 C 173.256 210 185.982 204.729 195.355 195.355 C 204.729 185.982 210 173.256 210 160 C 210 146.744 204.729 134.018 195.355 124.645 C 185.982 115.271 173.256 110 160 110 Z"
                    android:valueTo="M 160 60 C 133.489 60 108.036 70.543 89.289 89.289 C 70.543 108.036 60 133.489 60 160 C 60 186.511 70.543 211.964 89.289 230.711 C 108.036 249.457 133.489 260 160 260 C 186.511 260 211.964 249.457 230.711 230.711 C 249.457 211.964 260 186.511 260 160 C 260 133.489 249.457 108.036 230.711 89.289 C 211.964 70.543 186.511 60 160 60 Z"
                    android:valueType="pathType"
                    android:interpolator="@android:interpolator/fast_out_extra_slow_in" />
                <objectAnimator
                    android:propertyName="fillAlpha"
                    android:startOffset="200"
                    android:duration="200"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:valueType="floatType"
                    android:interpolator="@android:interpolator/fast_out_extra_slow_in" />
            </set>
        </aapt:attr>
    </target>
    <target android:name="logo_group">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:startOffset="400"
                    android:duration="500"
                    android:propertyName="translateX"
                    android:valueFrom="160"
                    android:valueTo="0"
                    android:interpolator="@android:interpolator/fast_out_extra_slow_in" />
                <objectAnimator
                    android:startOffset="400"
                    android:duration="500"
                    android:propertyName="translateY"
                    android:valueFrom="160"
                    android:valueTo="0"
                    android:interpolator="@android:interpolator/fast_out_extra_slow_in" />
                <objectAnimator
                    android:startOffset="400"
                    android:duration="500"
                    android:propertyName="scaleX"
                    android:valueFrom="0.25"
                    android:valueTo="0.5"
                    android:interpolator="@android:interpolator/fast_out_extra_slow_in" />
                <objectAnimator
                    android:startOffset="400"
                    android:duration="500"
                    android:propertyName="scaleY"
                    android:valueFrom="0.25"
                    android:valueTo="0.5"
                    android:interpolator="@android:interpolator/fast_out_extra_slow_in" />
            </set>
        </aapt:attr>
    </target>
    <target android:name="logo_ring">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="fillAlpha"
                    android:startOffset="400"
                    android:duration="300"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:valueType="floatType"
                    android:interpolator="@android:interpolator/fast_out_extra_slow_in" />
            </set>
        </aapt:attr>
    </target>
    <target android:name="logo_dot">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="fillAlpha"
                    android:startOffset="500"
                    android:duration="300"
                    android:valueFrom="0"
                    android:valueTo="1"
                    android:valueType="floatType"
                    android:interpolator="@android:interpolator/fast_out_extra_slow_in" />
            </set>
        </aapt:attr>
    </target>
    <target android:name="fg">
        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="scaleX"
                    android:startOffset="200"
                    android:duration="600"
                    android:valueFrom="0.5"
                    android:valueTo="1"
                    android:valueType="floatType"
                    android:interpolator="@android:interpolator/fast_out_extra_slow_in" />
                <objectAnimator
                    android:propertyName="scaleY"
                    android:startOffset="200"
                    android:duration="600"
                    android:valueFrom="0.5"
                    android:valueTo="1"
                    android:valueType="floatType"
                    android:interpolator="@android:interpolator/fast_out_extra_slow_in" />
            </set>
        </aapt:attr>
    </target>
</animated-vector>
